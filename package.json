{
  "name": "alitman22-portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node -e \"require('fs').copyFileSync('index.dev.html','index.html')\" && vite",
    "images:projects": "node scripts/generate-project-thumbnails.mjs",
    "build": "npm run images:projects && node -e \"require('fs').copyFileSync('index.dev.html','index.html')\" && vite build && npm run prerender",
    "build:spa": "npm run images:projects && node -e \"require('fs').copyFileSync('index.dev.html','index.html')\" && vite build",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "publish:local": "npm run build && node scripts/publish-local.mjs",
    "setup-hooks": "node -e \"const{copyFileSync,chmodSync}=require('fs');copyFileSync('scripts/pre-push.sh','.git/hooks/pre-push');try{chmodSync('.git/hooks/pre-push','755')}catch(e){};console.log('Hook installed.')\""
  },
  "dependencies": {
    "d3": "^7.9.0",
    "framer-motion": "^12.36.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "sharp": "^0.34.5",
    "vite": "^5.4.21"
  }
}
