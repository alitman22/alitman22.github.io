# Google Analytics 4 Measurement ID
# Replace with your GA4 web data stream measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Analytics server ────────────────────────────────────────────────────────
ANALYTICS_PORT=8787

# Turso database credentials (from: turso db show <name> && turso db tokens create <name>)
TURSO_DATABASE_URL=libsql://<your-db-name>-<your-org>.turso.io
TURSO_AUTH_TOKEN=<paste-turso-token-here>

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ANALYTICS_JWT_SECRET=<long-random-string-min-32-chars>

ANALYTICS_COOKIE_NAME=portfolio_analytics_session

ANALYTICS_ADMIN_USERNAME=admin

# Hash your password with: node server/tools/hash-password.mjs "YourPassword"
ANALYTICS_ADMIN_PASSWORD_HASH=<argon2id-hash-from-hash-password-tool>

# Optional TOTP 2FA — generate with: node server/tools/generate-totp.mjs
# Leave empty to disable 2FA
ANALYTICS_ADMIN_TOTP_SECRET=

# Allowed origins for CORS — change to your production domain when deploying
ANALYTICS_CORS_ORIGINS=http://localhost:5173,https://alitman22.github.io

ANALYTICS_TRUST_PROXY_HOPS=1

# Optional: path to MaxMind GeoLite2-City.mmdb for city/country lookup
MAXMIND_DB_PATH=./server/data/GeoLite2-City.mmdb

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Production URL of your deployed analytics server. Leave empty to use Vite dev proxy.
VITE_ANALYTICS_API_ORIGIN=

# Override local dev proxy target (default: http://localhost:8787)
VITE_ANALYTICS_PROXY_TARGET=http://localhost:8787
